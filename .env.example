# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here   # server-only, NEVER in client code

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 (must be 64+ chars)
JWT_SECRET=replace_with_64_char_random_secret_string_generated_by_openssl_rand_hex_32

# ─── Paystack ─────────────────────────────────────────────────────────────────
# Use sk_test_* for testing, sk_live_* in production
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
# Generate a separate secret: openssl rand -hex 32
PAYSTACK_WEBHOOK_SECRET=replace_with_separate_random_webhook_secret

# ─── Sendchamp (SMS OTP + notifications) ──────────────────────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC_. From your Sendchamp dashboard.
SENDCHAMP_API_KEY=your_sendchamp_api_key_from_sendchamp_dashboard
# Approved sender ID (must be approved in the Sendchamp dashboard)
SENDCHAMP_SENDER=LumeX
# OPTIONAL — route transactional NOTIFICATIONS over WhatsApp instead of SMS.
# Set BOTH once you have your own activated WhatsApp sender + a single-variable
# {{1}} "utility" template approved in Sendchamp. Unset = notifications use SMS.
SENDCHAMP_WA_SENDER=
SENDCHAMP_WA_TEMPLATE_CODE=

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Leave blank locally — rate limiting is silently skipped when not configured
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_DATABASE.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# Server + edge read SENTRY_DSN; the browser reads NEXT_PUBLIC_SENTRY_DSN (set
# both to the same value — a DSN is a write-only ingestion key, safe to expose).
SENTRY_DSN=https://YOUR_SENTRY_KEY@oXXXX.ingest.de.sentry.io/YOUR_PROJECT_ID
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_SENTRY_KEY@oXXXX.ingest.de.sentry.io/YOUR_PROJECT_ID
# Below are OPTIONAL — only needed to upload source maps (readable stack traces)
# during the build. Leave blank to skip upload (build still succeeds).
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug

# ─── Admin phones (E.164 format: +2348XXXXXXXXX) ─────────────────────────────
ADMIN_PHONE=+2348XXXXXXXXXX          # operational admin phone
SUPER_ADMIN_PHONE=+2348XXXXXXXXXX    # god mode — must differ from ADMIN_PHONE

# ─── Cron secret ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 24
CRON_SECRET=replace_with_random_32_char_secret

# ─── Google sign-in ("Continue with Google") ─────────────────────────────────
# OPTIONAL. Only needed if the super-admin "Continue with Google" feature flag is
# ON. Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud
# Console → APIs & Services → Credentials. Authorised redirect URI must be
# EXACTLY: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
#   e.g. http://localhost:3000/api/auth/google/callback   (dev)
#        https://lumex-fud.vercel.app/api/auth/google/callback   (prod)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# ─── Google Gemini (second AI provider) ───────────────────────────────────────
# OPTIONAL. Server-only — NEVER prefix with NEXT_PUBLIC_. There is ONE active AI
# provider for the whole app. AI_PROVIDER_DEFAULT seeds the INITIAL choice; after
# that the super-admin Controls page (🤖 AI provider) is the live switch — flip
# Gemini ↔ Anthropic with no redeploy. Keep ANTHROPIC_API_KEY set so Anthropic
# stays available as a fallback. A request carrying AUDIO (voice-note menus)
# always routes to Gemini regardless, since Anthropic can't read raw audio.
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL_VISION=gemini-2.5-flash
GEMINI_MODEL_TEXT=gemini-2.5-flash-lite
AI_PROVIDER_DEFAULT=gemini       # anthropic | gemini  (initial default only)

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # https://lumexfud.com.ng in production
